{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Hiroshi",
  "theme": "mint",
  "colors": {
    "primary": "#5B6AF0",
    "light": "#EEF0FF",
    "dark": "#1A1D3B"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/hiroshi-os/Hiroshi"
    }
